# ─── Client (Expo) ─────────────────────────────────────────────
# EXPO_PUBLIC_* vars are embedded in the app bundle. NEVER put secrets here.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your-public-mapbox-token

# ─── Server (Supabase Edge Functions) ──────────────────────────
# These live in supabase/.env (gitignored), NOT in the client bundle.
#   SUPABASE_URL=https://YOUR-PROJECT.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # bypasses RLS — server only
#   STRIPE_SECRET_KEY=sk_test_...
#   STRIPE_WEBHOOK_SECRET=whsec_...
#   STRIPE_CONNECT_CLIENT_ID=ca_...
#   MAPBOX_TOKEN=sk.your-secret-mapbox-token          # for Matrix/Directions API
