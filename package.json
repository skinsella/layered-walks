  "devDependencies": {
    "@babel/core": "^7.25.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "@types/react": "~18.3.0",
    "typescript": "~5.3.0",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0"
