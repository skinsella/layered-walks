    "react-native-url-polyfill": "^2.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@supabase/supabase-js": "^2.45.0",
    "@rnmapbox/maps": "^10.1.0",
    "@stripe/stripe-react-native": "0.40.0",
    "posthog-react-native": "^3.3.0"
